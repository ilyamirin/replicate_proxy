APP_NAME=Minimal OpenAI Chat Completions Server
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
APP_API_PREFIX=/v1
APP_HEALTH_PATH=/health
APP_PUBLIC_BASE_URL=
APP_MEDIA_PATH=/media
APP_MEDIA_ROOT=artifacts
APP_ECHO_EMPTY_RESPONSE=
ECHO_MODEL_ID=echo
ASSISTANT_MODEL_ID=assistant
ASSISTANT_ROUTER_MODEL_ID=gpt-5-nano
ASSISTANT_FULL_MODEL_ID=gpt-5.4
ASSISTANT_SQLITE_PATH=data/langgraph.sqlite
REPLICATE_API_TOKEN=
REPLICATE_BASE_URL=https://api.replicate.com/v1
REPLICATE_MODEL_MAP=gpt-5.4=openai/gpt-5.4,gpt-5-nano=openai/gpt-5-nano
REPLICATE_IMAGE_TOOL_ID=generate_image
REPLICATE_IMAGE_TOOL_MODEL=google/nano-banana-2
REPLICATE_IMAGE_OUTPUT_DIR=artifacts/images
REPLICATE_IMAGE_DOWNLOAD_OUTPUT=true
REPLICATE_QWEN_EDIT_TOOL_ID=edit_image_uncensored
REPLICATE_QWEN_EDIT_TOOL_MODEL=qwen/qwen-image-edit-plus
REPLICATE_QWEN_EDIT_OUTPUT_DIR=artifacts/qwen-edit
REPLICATE_QWEN_EDIT_DOWNLOAD_OUTPUT=true
REPLICATE_QWEN_EDIT_FORCE_DISABLE_SAFETY_CHECKER=true
REPLICATE_LOCAL_IMAGE_INPUT_ROOTS=tests/fixtures,artifacts/uploads
REPLICATE_DEFAULT_VERBOSITY=
REPLICATE_DEFAULT_MAX_COMPLETION_TOKENS=
REPLICATE_SYNC_WAIT_SECONDS=60
REPLICATE_POLL_INTERVAL_SECONDS=0.5
REPLICATE_POLL_TIMEOUT_SECONDS=90
REPLICATE_HTTP_TIMEOUT_SECONDS=90
REPLICATE_TRANSPORT_RETRIES=2
REPLICATE_TRANSPORT_RETRY_BACKOFF_SECONDS=0.5
