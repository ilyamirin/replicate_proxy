APP_NAME=Minimal OpenAI Chat Completions Server
APP_HOST=127.0.0.1
APP_PORT=8000
APP_API_PREFIX=/v1
APP_HEALTH_PATH=/health
APP_ECHO_EMPTY_RESPONSE=
ECHO_MODEL_ID=echo
REPLICATE_API_TOKEN=
REPLICATE_BASE_URL=https://api.replicate.com/v1
REPLICATE_MODEL_MAP=gpt-5.4=openai/gpt-5.4
REPLICATE_REASONING_EFFORT=none
REPLICATE_VERBOSITY=low
REPLICATE_MAX_COMPLETION_TOKENS=4096
REPLICATE_SYNC_WAIT_SECONDS=60
REPLICATE_POLL_INTERVAL_SECONDS=0.5
REPLICATE_POLL_TIMEOUT_SECONDS=90
REPLICATE_HTTP_TIMEOUT_SECONDS=90
